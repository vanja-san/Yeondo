<Window x:Class="Yeondo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Yeondo.ViewModels"
        xmlns:services="clr-namespace:Yeondo.Services"
        xmlns:converters="clr-namespace:Yeondo.Converters"
        xmlns:conv="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        mc:Ignorable="d"
        Height="500" Width="400"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <Window.Resources>
        <converters:StatusToIconConverter x:Key="StatusToIconConverter" />
        <converters:DetailsVisibilityConverter x:Key="DetailsVisibilityConverter" />
        <converters:FileNameConverter x:Key="FileNameConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:SourceIconConverter x:Key="SourceIconConverter" />
        <converters:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Панель кнопок -->
        <Border Grid.Row="0" Margin="12,8,12,0" Padding="8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <!-- Кнопки добавления -->
                <Button Grid.Column="0" Command="{Binding AddFilesCommand}"
                        ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.AddFilesTooltip}"
                        Margin="0,0,8,0">
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}"
                               Text="&#xED0E;"
                               FontSize="16"
                               Padding="0,1" />
                </Button>
                <Button Grid.Column="1" Command="{Binding AddFoldersCommand}"
                        ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.AddFoldersTooltip}">
                    <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}"
                               Text="&#xE8F4;"
                               FontSize="16"
                               Padding="0,1" />
                </Button>
                <!-- Выпадающий список для выбора типа ссылки -->
                <ComboBox Grid.Column="2"
                          SelectedItem="{Binding SelectedLinkType}"
                          HorizontalAlignment="Right">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="16"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static vm:LinkType.Junction}" />
                                                <DataTrigger Binding="{Binding}" Value="{x:Static vm:LinkType.HardLink}" />
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.LinkTypeSymbolic}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static vm:LinkType.Junction}">
                                                    <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.LinkTypeJunction}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="{x:Static vm:LinkType.HardLink}">
                                                    <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.LinkTypeHardLink}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.Items>
                        <vm:LinkType>Symbolic</vm:LinkType>
                        <vm:LinkType>Junction</vm:LinkType>
                        <vm:LinkType>HardLink</vm:LinkType>
                    </ComboBox.Items>
                </ComboBox>
                <!-- Кнопка создания -->
                <Button Grid.Column="3" Command="{Binding CreateCommand}"
                        Margin="8,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                    <Setter Property="Opacity" Value="0.5" />
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.CreateButton}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   Text="&#xE72A;"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <!-- Блок целевой папки -->
        <Border Grid.Row="1" Margin="12,8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                Padding="12,8,8,8">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <!-- Заголовок -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.OutputPathLabel}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                <!-- Путь (кликабельный) -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           FontSize="12"
                           Cursor="Hand"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.SelectPath}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TargetFolder}" Value="">
                                    <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.SelectPath}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <TextBlock.Text>
                        <Binding Path="TargetFolder" FallbackValue="" />
                    </TextBlock.Text>
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenTargetCommand}" />
                    </TextBlock.InputBindings>
                    <TextBlock.ToolTip>
                        <ToolTip Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.OpenFolderTooltip}" />
                    </TextBlock.ToolTip>
                </TextBlock>

                <!-- Кнопка -->
                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                        Command="{Binding BrowseTargetCommand}"
                        ToolTip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.BrowseTooltip}"
                        Margin="8,0,0,0">
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.BrowseButton}" VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Border>
        <!-- Блок вывода информации -->
        <Grid Grid.Row="2" Margin="8,0,8,2">
            <!-- Список элементов -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ItemsControlInstance" ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemBorder"
                                    Margin="4,2"
                                    Padding="8,6"
                                    CornerRadius="4"
                                    BorderThickness="0">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.RemoveMenuItem}"
                                                  Command="{Binding DataContext.RemoveItemCommand, Source={x:Reference ItemsControlInstance}}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource ControlAltFillColorTransparentBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid ColumnDefinitions="Auto,*">
                                    <!-- Иконка или спиннер -->
                                    <Grid Grid.Column="0" Width="20" Height="20" Margin="0,0,12,0">
                                        <!-- Статичная иконка -->
                                        <TextBlock x:Name="StatusIcon"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Converter={StaticResource SourceIconConverter}}" />
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Success">
                                                            <Setter Property="Text" Value="&#xE73E;" />
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                            <Setter Property="Text" Value="&#xE711;" />
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Спиннер -->
                                        <ProgressBar x:Name="ProgressSpinner"
                                                     IsIndeterminate="True"
                                                     Width="16" Height="16"
                                                     VerticalAlignment="Center"
                                                     HorizontalAlignment="Center">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                    </Grid>
                                    <!-- Путь -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SourcePath, Converter={StaticResource FileNameConverter}}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                            <TextBlock.ToolTip>
                                                <ToolTip Content="{Binding SourcePath}" />
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.SuccessMessage}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                       Visibility="{Binding Status, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Success}" />
                                            <TextBlock Text="{Binding ErrorMessage}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        <!-- Статусбар -->
        <Border Grid.Row="3"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <Grid ColumnDefinitions="*,Auto,Auto" Margin="12,8">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{Binding StatusText}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}" Value="">
                                    <Setter Property="Text" Value="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.ReadyStatus}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Grid.Column="1" Command="{Binding OpenLogsCommand}"
                        Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.LogsButton}"
                        FontSize="12"
                        Padding="4,2"
                        Margin="0,0,4,0"
                        Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button Grid.Column="2" Command="{Binding ClearCommand}"
                        Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=Resources.ClearButton}"
                        FontSize="12"
                        Padding="4,2"
                        Visibility="{Binding Items.Count, Converter={StaticResource CountToVisibilityConverter}}" />
            </Grid>
        </Border>
        <!-- Индикатор занятости -->
        <Border Grid.Row="3" IsHitTestVisible="False"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Height="3"
                         VerticalAlignment="Bottom"
                         Background="Transparent"
                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"/>
        </Border>
    </Grid>
</Window>
